{
  "name": "hello-world-function-template",
  "version": "1.0.0",
  "description": "Minimal Azure Functions Hello World template",
  "private": true,
  "main": "dist/src/functions/helloWorld.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run build",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "prestart": "npm run clean && npm run build",
    "start": "func start",
    "test": "npm run build && node --test tests/*.test.js"
  },
  "dependencies": {
    "@azure/functions": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=22 <23"
  }
}
