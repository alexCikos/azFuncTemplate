{
  "name": "invoice-tracker-functions",
  "version": "1.0.0",
  "description": "Azure Functions app for the Invoice Tracker demo",
  "private": true,
  "main": "dist/src/functions/*.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run build",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "prestart": "npm run clean && npm run build",
    "start": "func start",
    "test": "echo \"No automated tests yet\""
  },
  "dependencies": {
    "@azure/functions": "^4.0.0",
    "axios": "^1.13.6"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=22 <23"
  }
}
